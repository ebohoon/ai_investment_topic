# --- 로컬: server/.env 로 복사 ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
PORT=3001

# MongoDB (로컬 또는 Atlas). Vercel 배포 시 대시보드 Environment Variables에도 동일하게 등록
# Atlas 예: mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=
MONGODB_DB=aicc
MONGODB_COLLECTION=generated_sessions

# Vercel 빌드만 할 때는 클라이언트용 (API를 다른 도메인에 둘 경우에만)
# VITE_API_BASE=https://your-api.example.com
