# 로컬 API 서버용: client/server/.env 로 복사
# Vercel 배포 시: GitHub에 넣지 말고, Vercel 대시보드 Environment Variables에 동일 이름으로 등록
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
PORT=3001

# 쉼표로 구분. 비우면 개발 편의상 모든 Origin 허용. 운영 시 예: https://myapp.vercel.app,http://localhost:5173
ALLOWED_ORIGINS=

MONGODB_URI=
MONGODB_DB=aicc
MONGODB_COLLECTION=generated_sessions

# VITE_API_BASE=https://...
